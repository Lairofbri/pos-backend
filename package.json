{
  "name": "pos-backend",
  "version": "1.0.0",
  "description": "Backend POS multi-restaurante El Salvador",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "pnpm build && node --watch dist/server.js",
    "dev:ts": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migrations/run.ts",
    "test": "node --test tests/integration/auth.test.cjs",
    "test:ts": "pnpm run build && node --test dist/tests/integration/auth.test.js",
    "test:auth": "node --test tests/integration/auth.test.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src/",
    "lint:ts": "eslint src/ --ext .ts",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@scalar/express-api-reference": "^0.9.20",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.2",
    "multer": "^2.2.0",
    "node-thermal-printer": "^4.6.0",
    "pg": "^8.12.0",
    "sharp": "^0.35.2",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/moment-timezone": "^0.5.30",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "proxyquire": "^2.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
