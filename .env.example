# =============================================
# POS BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores
# =============================================

# Servidor
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL (Docker local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_backend
# En Docker local SSL no es necesario, se deja true por defecto
# Solo desactivar si hay errores de certificado
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT — genera un string aleatorio largo y seguro
JWT_SECRET=cambia_esto_por_un_secret_muy_largo_y_aleatorio_min_64_chars
JWT_EXPIRES_IN=1h

# JWT para refresh tokens (sesiones más largas en modo offline)
JWT_REFRESH_SECRET=otro_secret_diferente_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Logs
LOG_LEVEL=info

# Cloudflare R2 — imágenes de productos (S3-compatible)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret_key
R2_BUCKET_NAME=pos-productos
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
