# =============================================
# POS BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores
# =============================================

# Servidor
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL (Railway te da esta URL completa)
DATABASE_URL=postgresql://usuario:password@host:5432/pos_db

# JWT — genera un string aleatorio largo y seguro
JWT_SECRET=cambia_esto_por_un_secret_muy_largo_y_aleatorio_min_64_chars
JWT_EXPIRES_IN=8h

# JWT para refresh tokens (sesiones más largas en modo offline)
JWT_REFRESH_SECRET=otro_secret_diferente_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Logs
LOG_LEVEL=info
